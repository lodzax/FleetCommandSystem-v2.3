{
  "name": "fleetcommand",
  "private": true,
  "version": "2.3.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "server": "npx tsx server/index.ts",
    "dev:all": "npx concurrently \"npm run server\" \"npm run dev\"",
    "start": "node server/prod.cjs",
    "deploy": "npm run build && npm run start",
    "db:init": "npx tsx -e \"const mysql=require('mysql2/promise');const fs=require('fs');(async()=>{const p=await mysql.createConnection({host:'localhost',user:'root',password:'',multipleStatements:true});await p.query(fs.readFileSync('server/schema.sql','utf8'));console.log('DB initialized');await p.end()})()\"",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.22.2",
    "html5-qrcode": "^2.3.8",
    "jsbarcode": "^3.12.3",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.2.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "mysql2": "^3.22.4",
    "nodemailer": "^8.0.10",
    "qrcode": "^1.5.4",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-hot-toast": "^2.6.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.15.1",
    "recharts": "^3.8.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsbarcode": "^3.11.4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.0",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
