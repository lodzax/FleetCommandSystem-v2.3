# FleetCommand v2.3 — Production Configuration
# Copy this file to .env and fill in your values.

# MySQL Database Configuration (use cPanel MySQL credentials)
DB_HOST="localhost"
DB_PORT="3306"
DB_USER="npivfupq_fleet"
DB_PASSWORD="your_mysql_password"
DB_NAME="npivfupq_fleet"

# JWT Authentication Secret (REQUIRED — set a strong random string)
JWT_SECRET="change-this-to-a-random-secret-string"

# Gemini AI API Key (optional)
GEMINI_API_KEY=""

# App URL (production domain)
APP_URL="https://fleet.mineazy.co.zw"

# API Server Port (cPanel Node.js apps usually use a port assigned by the panel)
API_PORT="3001"

# SMTP Email Configuration (for requisition notifications)
SMTP_HOST="mail.mineazy.co.zw"
SMTP_PORT="465"
SMTP_USER="notifications@mineazy.co.zw"
SMTP_PASS="your_smtp_password"
SMTP_FROM_NAME="FleetCommand Notifications"

# cPanel API Token (for automated deployments)
CPANEL_TOKEN=""
