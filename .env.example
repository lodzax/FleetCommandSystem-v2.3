# FleetCommand v2.3 — Production Configuration
# Copy this file to .env and fill in your values.

# MySQL Database Configuration (use cPanel MySQL credentials)
DB_HOST="localhost"
DB_PORT="3306"
DB_USER="npivfupq_fleet"
DB_PASSWORD="your_mysql_password"
DB_NAME="npivfupq_fleet"

# JWT Authentication Secret (change to a strong random string)
JWT_SECRET="change-this-to-a-random-secret-string"

# Gemini AI API Key (optional)
GEMINI_API_KEY=""

# App URL (production domain)
APP_URL="https://fleet.mineazy.co.zw"

# API Server Port (cPanel Node.js apps usually use a port assigned by the panel)
API_PORT="3001"
